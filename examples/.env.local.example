# Copy this file to .env.local and fill in your key.
# .env.local is gitignored.
#
# The Vite dev server reads this server-side and proxies planner calls
# to api.anthropic.com via /api/plan. The browser never sees the key.
# No more dangerouslyAllowBrowser, no CORS issues with org-issued keys.
#
# The legacy VITE_ANTHROPIC_API_KEY also works if it's the only one set
# (backwards compat for older .env.local files), but new installs should
# use the unprefixed names below.

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
