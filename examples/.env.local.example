# Copy this file to .env.local and fill in your key.
# .env.local is gitignored.
#
# The playground calls the Anthropic API from the browser with
# `dangerouslyAllowBrowser: true`. This is dev-only — a production
# deployment would proxy through a server to keep the key off-client.

VITE_ANTHROPIC_API_KEY=sk-ant-...
VITE_ANTHROPIC_MODEL=claude-sonnet-4-7
